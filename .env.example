# Turso — https://turso.tech (local dev: file:local.db with empty token)
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# 32-byte base64 key for AES-256-GCM field encryption (src/lib/crypto.ts).
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Canonical public URL of the deployment
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth.js — generate with: npx auth secret (or: openssl rand -base64 32)
AUTH_SECRET=

# Optional, comma-separated (e.g. you@example.com,partner@example.com).
# Leave empty for an open instance (anyone who signs up can start a family).
# Restricts who may create a *new* family on this deployment — invited
# members always get in via the invite code, regardless of this list.
AUTH_ALLOWED_EMAILS=
