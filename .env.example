# Turso — https://turso.tech (local dev: file:local.db with empty token)
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# 32-byte base64 key for AES-256-GCM field encryption (src/lib/crypto.ts).
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Canonical public URL of the deployment
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth.js — generate with: npx auth secret (or: openssl rand -base64 32)
AUTH_SECRET=

# Optional, comma-separated (e.g. you@example.com,partner@example.com).
# Leave empty for an open instance (anyone can sign up and start a family).
# Restricts who may sign up (create an account) AND who may create a *new*
# family on this deployment. Joining an existing family via invite code is
# never gated by this list directly — but joining still requires an
# account first, so on a closed instance every invitee's email must also
# be added here before they can sign up and use their invite code.
AUTH_ALLOWED_EMAILS=
